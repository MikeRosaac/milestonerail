    "foreign_key": {
      "of": "organizations",
      "key": "id"
    },
    "indexable": true
  },
  "milestone_id": {
    "type": "Number",
    "foreign_key": {
      "of": "milestones",
      "key": "id"
    },
    "indexable": true
  },
  "learner_id": {
    "type": "Number",
