{
  "id": {
    "type": "Number",
    "primary_key": true,
    "auto_increment": true
  },
  "organization_id": {
    "type": "Number",
    "foreign_key": {
      "of": "organizations",
      "key": "id"
    },
    "indexable": true
  },
  "submission_id": {
    "type": "Number",
    "foreign_key": {
      "of": "submissions",
      "key": "id"
    },
    "indexable": true
  },
  "actor_id": {
    "type": "Number",
    "foreign_key": {
      "of": "users",
      "key": "id"
    },
    "optional": true,
    "indexable": true
  },
  "actor_name": {
    "type": "String",
    "max_length": 160
  },
  "actor_role": {
    "type": "String",
    "max_length": 20
  },
  "event_type": {
    "type": "String",
    "max_length": 64,
    "indexable": true
  },
  "event_key": {
    "type": "String",
    "max_length": 255,
    "indexable": true
  },
  "title": {
    "type": "String",
    "max_length": 255
  },
  "detail": {
    "type": "String",
    "max_length": 4000
  },
  "metadata": {
    "type": "JSON_OBJECT",
    "optional": true,
    "properties": {
      "providerReference": {
        "type": "String",
        "max_length": 160,
        "optional": true
      },
      "providerEventId": {
        "type": "String",
        "max_length": 160,
        "optional": true
      },
      "status": {
        "type": "String",
        "max_length": 64,
        "optional": true
      },
      "dedupeKey": {
        "type": "String",
        "max_length": 255,
        "optional": true
      }
    }
  },
  "created_at": {
    "type": "DateTime",
    "indexable": true
  }
}
