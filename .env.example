# Production must point at a deployed Sub0 project.
VITE_SUB0_HTTP_URL=https://your-sub0-project.example.com
VITE_SUB0_WS_URL=wss://your-sub0-project.example.com/ws

# Local development can run against deterministic in-browser fixtures.
# Never enable this on the judged LingoQL deployment.
VITE_DEMO_MODE=true
